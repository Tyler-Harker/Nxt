#!/usr/bin/env bash
# Run the sample with the Nxt dev watcher — debounced, serialized rebuilds.
# No hot reload; full restart on every change, but the watcher coalesces rapid
# edits and never starts a build while another build/run is in flight.
#
#   ./dev-sample                       # http://localhost:8080
#   PORT=5099 ./dev-sample             # custom port
#   NXT_DEBOUNCE_MS=1500 ./dev-sample
#
set -euo pipefail
REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
exec dotnet run \
    --project "$REPO_ROOT/tools/Nxt.DevWatcher/Nxt.DevWatcher.csproj" \
    --no-launch-profile \
    -- \
    --project "$REPO_ROOT/samples/SampleApp/SampleApp.csproj" \
    --urls "http://localhost:${PORT:-8080}" \
    "$@"
